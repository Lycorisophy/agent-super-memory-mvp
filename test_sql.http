### 变量配置（请根据实际环境修改）
@baseUrl = http://localhost:8000
@mode = auto_execute
### 如需实际执行并返回数据，将 @mode 改为 auto_execute

###############################################
# 查询用例 Q-01
# 查询所有用户的用户名和所在城市
###############################################
POST {{baseUrl}}/schema/query
Content-Type: application/json

{
  "query": "查询所有用户的用户名和所在城市。",
  "mode": "{{mode}}",
  "agent_mode":"react"
}

###############################################
# 查询用例 Q-02
# 统计每个用户的下单总金额，按金额从高到低排序
###############################################
POST {{baseUrl}}/schema/query
Content-Type: application/json

{
  "query": "统计每个用户的下单总金额，按金额从高到低排序。",
  "mode": "{{mode}}",
  "agent_mode":"react"
}

